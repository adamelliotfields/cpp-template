{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug convertunit",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/convertunit",
      "args": ["1", "--from", "km", "--to", "m"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "CMake: build (debug)"
    }
  ]
}
